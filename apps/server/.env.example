# Wonderlands server local development environment.
# Copy to apps/server/.env or run `npm run setup` from the repository root.
# Keep real secrets in apps/server/.env only; this file is safe to commit.

# App / HTTP
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
API_BASE_PATH=/v1
LOG_LEVEL=info

# Auth
AUTH_MODE=api_key
AUTH_METHODS=api_key,auth_session
AUTH_SESSION_SAME_SITE=lax
AUTH_SESSION_SECURE=false

# Local data. For production, use absolute paths outside the repository checkout.
DATABASE_PATH=./var/05_04_api.sqlite
FILE_STORAGE_KIND=local
FILE_STORAGE_ROOT=./var/files

# AI providers. Set at least one provider key for useful local runs.
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-5.4
OPENAI_IMAGE_DEFAULT_MODEL=gpt-image-1.5
OPENAI_ORGANIZATION=
OPENAI_PROJECT_ID=
OPENAI_SERVICE_TIER=auto
OPENAI_WEBHOOK_SECRET=

GOOGLE_API_KEY=
GOOGLE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_API_VERSION=
GOOGLE_BASE_URL=
GOOGLE_DEFAULT_MODEL=gemini-3.1-pro-preview
GOOGLE_IMAGE_DEFAULT_MODEL=gemini-3.1-flash-image-preview

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.4
OPENROUTER_IMAGE_DEFAULT_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=
OPENROUTER_APP_CATEGORIES=

# Optional Langfuse tracing
LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENVIRONMENT=development
LANGFUSE_TIMEOUT_MS=5000

# Workers
MULTIAGENT_WORKER_AUTO_START=true
MULTIAGENT_WORKER_POLL_MS=500
MULTIAGENT_LEASE_TTL_MS=30000
MULTIAGENT_MAX_RUN_TURNS=50
MULTIAGENT_MAX_STALE_RECOVERIES=3
MULTIAGENT_STALE_RECOVERY_BASE_DELAY_MS=30000

GARDEN_WORKER_AUTO_START=true
GARDEN_WORKER_POLL_MS=1000
GARDEN_WORKER_DEBOUNCE_MS=2000

AGENT_TASK_WORKER_AUTO_START=true
AGENT_TASK_WORKER_POLL_MS=15000
AGENT_TASK_WORKER_BATCH_SIZE=10

# File uploads / request limits
MAX_REQUEST_BODY_BYTES=1048576
FILE_MAX_UPLOAD_BYTES=1048576
FILE_INLINE_TEXT_BYTES=65536
FILE_ALLOWED_MIME_TYPES=image/*,text/*,application/pdf

# Memory
MEMORY_COMPACTION_RAW_ITEMS=200
MEMORY_OBSERVATION_TRIGGER_RATIO=0.75
MEMORY_OBSERVATION_TAIL_RATIO=0.25
MEMORY_REFLECTION_TRIGGER_RATIO=0.75

# MCP
# Generate manually with: openssl rand -hex 32
MCP_SECRET_ENCRYPTION_KEY=
MCP_SERVERS_FILE=./.mcp-servers.json

# Browser sandbox (Kernel). `npm run setup` enables local Kernel by default.
KERNEL_ENABLED=false
KERNEL_PROVIDER=local
KERNEL_CDP_URL=http://127.0.0.1:9222
KERNEL_LOCAL_API_URL=http://127.0.0.1:10001
KERNEL_API_URL=https://api.kernel.sh
KERNEL_API_KEY=

# Optional lo sandbox runtime. Use absolute paths if enabled.
SANDBOX_PROVIDER=local_dev
SANDBOX_LO_BINARY=
SANDBOX_LO_BOOTSTRAP_ENTRY=

# Long-poll/follow endpoint cap
EVENT_STREAM_MAX_FOLLOW_MS=300000
