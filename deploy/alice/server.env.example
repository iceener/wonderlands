# Copy to /home/alice/wonderlands/shared/server.env on the VPS.
# Fill secrets on the VPS only. Do not commit real values.

NODE_ENV=production
HOST=127.0.0.1
PORT=3001
API_BASE_PATH=/api
LOG_LEVEL=info

AUTH_MODE=api_key
AUTH_METHODS=api_key,auth_session
AUTH_SESSION_SECURE=true
AUTH_SESSION_SAME_SITE=lax
CORS_ALLOW_ORIGINS=https://overment.ai

DATABASE_PATH=/home/alice/wonderlands/shared/var/05_04_api.sqlite
FILE_STORAGE_KIND=local
FILE_STORAGE_ROOT=/home/alice/wonderlands/shared/var/files

# Set at least one model provider.
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5.4
GOOGLE_API_KEY=
GOOGLE_DEFAULT_MODEL=gemini-3.1-pro-preview
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-5.4

# Generate with: openssl rand -hex 32
MCP_SECRET_ENCRYPTION_KEY=
# Optional. If set, create the file on the VPS; an empty file should contain [].
# MCP_SERVERS_FILE=/home/alice/wonderlands/shared/.mcp-servers.json

KERNEL_ENABLED=false
KERNEL_PROVIDER=local
KERNEL_CDP_URL=http://127.0.0.1:9222
KERNEL_LOCAL_API_URL=http://127.0.0.1:10001

SANDBOX_PROVIDER=local_dev
SANDBOX_LO_BINARY=
SANDBOX_LO_BOOTSTRAP_ENTRY=
